# ═══════════════════════════════════════════════════════════════════
#  HotelOS — Template variabili d'ambiente
#  Per istruzioni dettagliate vedere docs/GUIDA_DEPLOY.md
# ═══════════════════════════════════════════════════════════════════


# ── BACKEND ─────────────────────────────────────────────────────────
# Copiare questo blocco in:  backend/.env

# Connessione PostgreSQL
# Formato: postgresql://utente:password@host:porta/nome_database
# Su macOS (sviluppo, auth via peer):  postgresql://TUO_UTENTE_MAC@localhost:5432/revenue_master
# Su Linux (produzione):               postgresql://revenue_user:PASSWORD@localhost:5432/revenue_master
DATABASE_URL=postgresql://UTENTE:PASSWORD@localhost:5432/revenue_master

# Chiave segreta per la firma dei token JWT — OBBLIGATORIO cambiarla in produzione
# Generare con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_QUESTA_CHIAVE_CON_UNA_STRINGA_CASUALE_LUNGA

# Modalità debug (true in sviluppo, false in produzione)
DEBUG=false

# Cartella dove vengono salvati i file CSV/Excel caricati (relativa a backend/)
UPLOADS_DIR=../uploads


# ── FRONTEND ────────────────────────────────────────────────────────
# Editare:  frontend/.env.production  prima di eseguire npm run build

# URL del backend raggiungibile dal browser degli utenti
# Sviluppo:   http://localhost:8000
# Produzione: https://tuodominio.it   oppure   http://IP_SERVER:8000
VITE_API_URL=https://tuodominio.it


# ── CONFIGURAZIONE NEL DATABASE (tabella app_config) ────────────────
# Questi valori NON vanno in .env — si modificano direttamente nel DB.
# Comandi SQL da eseguire dopo il primo avvio:
#
#   UPDATE app_config SET value = 'https://tuodominio.it'
#     WHERE key = 'cors_origins';
#
#   UPDATE app_config SET value = 'Nome Applicazione'
#     WHERE key = 'app_name';
#
# Chiavi disponibili:
#   cors_origins                   — origini CORS autorizzate (separato da virgola)
#   app_name                       — nome mostrato nella navbar
#   week_start_weekday             — 5 = sabato (non modificare)
#   anno_confronto_giorni_offset   — 364 (non modificare)
#   anno_confronto_tolleranza_giorni — 30 (non modificare)
